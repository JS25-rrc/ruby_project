<h1 class="mb-4">Search Products</h1>

<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: search_path, method: :get, class: "row g-3 align-items-end" do |f| %>
      <div class="col-md-6">
        <%= f.label :query, "Keyword", class: "form-label" %>
        <%= f.text_field :query, value: @query, placeholder: "Search...", class: "form-control" %>
      </div>
      <div class="col-md-4">
        <%= f.label :category_id, "Category", class: "form-label" %>
        <%= f.select :category_id,
          options_from_collection_for_select(@categories, :id, :name, @category_id),
          { include_blank: "All Categories" },
          { class: "form-select" } %>
      </div>
      <div class="col-md-2">
        <%= f.submit "Search", class: "btn btn-dark w-100" %>
      </div>
    <% end %>
  </div>
</div>

<% if @query.present? || @category_id.present? %>
  <p class="text-muted"><%= @products.count %> result(s)</p>
  <% if @products.any? %>
    <div class="row">
      <% @products.each do |product| %>
        <%= render product %>
      <% end %>
    </div>
  <% else %>
    <p>No products found.</p>
  <% end %>
<% end %>