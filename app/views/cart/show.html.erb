<h1 class="mb-4">Your Cart</h1>

<% if @cart_items.empty? %>
  <p class="text-muted">Your cart is empty.</p>
  <%= link_to "Continue Shopping", products_path, class: "btn btn-dark" %>
<% else %>
  <div class="row">
    <div class="col-md-8">
      <% @cart_items.each do |item| %>
        <div class="card mb-3">
          <div class="card-body d-flex justify-content-between align-items-center">
            <div>
              <h5 class="mb-1"><%= link_to item[:product].name, item[:product], class: "text-decoration-none" %></h5>
              <p class="text-muted mb-0">$<%= item[:unit_price] %> each</p>
            </div>
            <div class="d-flex align-items-center gap-3">
              <%= form_with url: cart_item_path(item[:product].id), method: :patch, class: "d-flex align-items-center gap-2" do |f| %>
                <%= f.number_field :quantity, value: item[:quantity], min: 1, class: "form-control form-control-sm", style: "width: 70px" %>
                <%= f.submit "Update", class: "btn btn-outline-secondary btn-sm" %>
              <% end %>
              <%= button_to "Remove", cart_item_path(item[:product].id), method: :delete, class: "btn btn-outline-danger btn-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Order Summary</h5>
          <% total = @cart_items.sum { |i| i[:unit_price] * i[:quantity] } %>
          <p class="d-flex justify-content-between"><span>Subtotal</span><strong>$<%= total.round(2) %></strong></p>
          <hr>
          <%= link_to "Proceed to Checkout", checkout_path, class: "btn btn-dark w-100" %>
          <%= link_to "Continue Shopping", products_path, class: "btn btn-outline-secondary w-100 mt-2" %>
        </div>
      </div>
    </div>
  </div>
<% end %>