<h1>Your Cart</h1>

<% if @cart_items.empty? %>
  <p>Your cart is empty.</p>
<% else %>
  <% @cart_items.each do |item| %>
    <div>
      <p><%= item[:product].name %> — $<%= item[:product].price %></p>

      <%= form_with url: cart_item_path(item[:product].id), method: :patch do |f| %>
        <%= f.number_field :quantity, value: item[:quantity], min: 1 %>
        <%= f.submit "Update" %>
      <% end %>

      <%= button_to "Remove", cart_item_path(item[:product].id), method: :delete %>
    </div>
  <% end %>
<% end %>

<%= link_to "Continue Shopping", products_path %>
<%= link_to "Proceed to Checkout", checkout_path %>