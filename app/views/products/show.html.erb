<div class="row">
  <div class="col-md-5">
    <% if @product.image.attached? %>
      <%= image_tag @product.image, class: "img-fluid rounded" %>
    <% else %>
      <div class="rounded d-flex align-items-center justify-content-center" style="height: 300px; background-color: #f0f4f0;">
        <span class="text-muted">No image</span>
      </div>
    <% end %>
  </div>
  <div class="col-md-7">
    <h1><%= @product.name %></h1>
    <p class="text-muted"><%= @product.description %></p>

    <% if @product.on_sale && @product.sale_price %>
      <p><s class="text-muted">$<%= @product.price %></s></p>
      <p class="text-danger fw-bold fs-4">$<%= @product.sale_price %> <small>(Save $<%= (@product.price - @product.sale_price).round(2) %>)</small></p>
    <% else %>
      <p class="fw-bold fs-4">$<%= @product.price %></p>
    <% end %>

    <%= form_with url: cart_items_path, method: :post, class: "d-flex align-items-center gap-2 mt-3" do |f| %>
      <%= f.hidden_field :product_id, value: @product.id %>
      <%= f.number_field :quantity, value: 1, min: 1, class: "form-control w-25" %>
      <%= f.submit "Add to Cart", class: "btn btn-dark" %>
    <% end %>

    <div class="mt-3">
      <%= link_to "Back", products_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>
</div>