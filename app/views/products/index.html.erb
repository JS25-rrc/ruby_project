<div class="p-5 mb-4 rounded" style="background-color: #f0f4f0; border-left: 4px solid #2d4a2d;">
  <h2 class="fw-bold">Gear Up for the Outdoors</h2>
  <p class="text-muted mb-0">Tents, hiking gear, winter sports equipment and more — all in one place.</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0">All Products</h4>
  <div>
    <%= link_to "All", products_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to "On Sale", products_path(filter: "on_sale"), class: "btn btn-outline-danger btn-sm" %>
    <%= link_to "New", products_path(filter: "new"), class: "btn btn-outline-success btn-sm" %>
    <%= link_to "Recently Updated", products_path(filter: "recently_updated"), class: "btn btn-outline-primary btn-sm" %>
  </div>
</div>

<div class="row">
  <%= render @products %>
</div>