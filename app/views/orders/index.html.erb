<h1>Your Orders</h1>

<% if @orders.empty? %>
  <p>You have no orders yet.</p>
<% else %>
  <% @orders.each do |order| %>
    <div>
      <p>Order #<%= order.id %> — <%= order.created_at.strftime("%B %d, %Y") %></p>
      <p>Status: <%= order.status %></p>
      <p>Grand Total: $<%= order.grand_total %></p>
      <%= link_to "View Details", order_path(order) %>
    </div>
    <hr>
  <% end %>
<% end %>