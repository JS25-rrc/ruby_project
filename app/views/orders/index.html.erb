<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>My Orders</h1>
</div>

<% if @orders.empty? %>
  <p class="text-muted">You have no orders yet.</p>
  <%= link_to "Start Shopping", products_path, class: "btn btn-dark" %>
<% else %>
  <% @orders.each do |order| %>
    <div class="card mb-3">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div>
          <h5 class="mb-1">Order #<%= order.id %></h5>
          <p class="text-muted mb-0"><%= order.created_at.strftime("%B %d, %Y") %></p>
        </div>
        <div class="text-end">
          <span class="badge bg-dark mb-2"><%= order.status %></span>
          <p class="mb-1">$<%= order.grand_total %></p>
          <%= link_to "View Details", order_path(order), class: "btn btn-outline-dark btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
<% end %>